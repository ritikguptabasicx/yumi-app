{
  "expo": {
    "name": "Yumi",
    "slug": "yumi-catering",
    "version": "1.0.0",
    "orientation": "portrait",

    "icon": "./assets/app-icon.png",

    "scheme": "yumi",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,

    "splash": {
      "image": "./assets/app-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#019C7F"
    },

    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.weblike.yumi"
    },

    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/app-icon.png",
        "backgroundColor": "#019C7F"
      },
      "package": "com.weblike.yumi",
      "softwareKeyboardLayoutMode": "pan",
      "permissions": ["android.permission.RECORD_AUDIO"]
    },

    "plugins": [
      "expo-router",
      "expo-secure-store",

      [
        "expo-notifications",
        {
          "icon": "./assets/app-icon.png",
          "color": "#019C7F"
        }
      ],

      [
        "expo-image-picker",
        {
          "photosPermission": "Allow Yumi to access your photos for profile pictures."
        }
      ]
    ],

    "experiments": {
      "typedRoutes": true
    },

    "extra": {
      "router": {},
      "eas": {
        "projectId": "9f5b31d4-6fec-4bca-88dd-022473c28209"
      },
      "EXPO_PUBLIC_API_BASE_URL": "https://devapi.yumi.ro"
    }
  }
}